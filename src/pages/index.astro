<style>
  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:       #0c0c0c;
    --ink-soft:  #3a3a3a;
    --ink-muted: #888888;
    --line:      #e8e8e8;
    --bg:        #ffffff;
    --max:       660px;
    --serif:     'Cormorant Garamond', Georgia, serif;
    --sans:      'Inter', system-ui, -apple-system, sans-serif;
  }

  html { font-size: 17px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.85;
    -webkit-font-smoothing: antialiased;
  }

  p { max-width: 58ch; }
  p + p { margin-top: 1.1rem; }

  a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--line);
    transition: text-decoration-color 0.15s;
  }
  a:hover { text-decoration-color: var(--ink-muted); }

  strong { font-weight: 500; }

  hr {
    border: none;
    border-top: 1px solid var(--line);
  }

  /* ── Layout ── */
  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section > .container {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  /* ── Hero ── */
  .hero > .container { padding-top: 5rem; padding-bottom: 5rem; }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
  }

  .hero-text { flex: 1; }

  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 3.2rem;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 0.6rem;
  }

  .tagline {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .hero-photo {
    width: 148px;
    height: 148px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 15%;
    flex-shrink: 0;
    filter: grayscale(8%) contrast(1.02);
  }

  /* ── Labels ── */
  .label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  /* ── Credentials ── */
  .cred-stack {
    display: flex;
    flex-direction: column;
  }

  .cred-block {
    padding: 1.5rem 0;
  }

  .cred-block--second {
    border-top: 1px solid var(--line);
  }

  .cred-title {
    font-weight: 600;
    font-size: 0.88rem;
    margin-bottom: 0.5rem;
    max-width: none;
    letter-spacing: 0.01em;
  }

  .cred-block p:not(.cred-title) {
    font-size: 0.88rem;
    color: var(--ink-muted);
    max-width: none;
  }

  /* ── Publications ── */
  .publications ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .publications li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1rem;
    border-left: 1px solid var(--line);
  }

  .publications a {
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration-color: transparent;
  }
  .publications a:hover { text-decoration-color: var(--ink-muted); }

  .pub-meta {
    font-size: 0.78rem;
    color: var(--ink-muted);
    max-width: none;
  }

  /* ── Social ── */
  .social-links {
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin-top: 1.5rem;
  }

  .social-links a { color: var(--ink-muted); }
  .social-links a:hover { color: var(--ink); text-decoration-color: var(--ink-muted); }

  .dot { margin: 0 0.35rem; color: var(--line); }

  /* ── Email ── */
  .email {
    display: inline-block;
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    margin-top: 1.25rem;
    transition: opacity 0.15s;
  }
  .email:hover { opacity: 0.45; }

  /* ── Footer ── */
  footer { border-top: 1px solid var(--line); }

  .footer-inner {
    padding-top: 1.75rem;
    padding-bottom: 1.75rem;
    font-size: 0.78rem;
    color: var(--ink-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 540px) {
    h1 { font-size: 2.4rem; }

    .hero-inner {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 1.75rem;
    }

    .hero-photo { width: 110px; height: 110px; }


    .hero > .container { padding-top: 3.5rem; padding-bottom: 3.5rem; }
  }
</style>
