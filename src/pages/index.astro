<style>
  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:       #0c0c0c;
    --ink-soft:  #3a3a3a;
    --ink-muted: #888888;
    --line:      #e8e8e8;
    --bg:        #ffffff;
    --max:       620px;
    --sans:      'Inter', system-ui, -apple-system, sans-serif;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 400;
    line-height: 1.8;
    -webkit-font-smoothing: antialiased;
  }

  p { max-width: 56ch; }
  p + p { margin-top: 1rem; }

  a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--line);
    transition: text-decoration-color 0.15s;
  }
  a:hover { text-decoration-color: var(--ink-muted); }

  strong { font-weight: 500; }

  hr {
    border: none;
    border-top: 1px solid var(--line);
  }

  /* ── Layout ── */
  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section > .container {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  /* ── Hero ── */
  .hero {
    max-width: 960px;
    margin: 0 auto;
    padding: 4.5rem 2rem 5rem;
  }

  .greeting {
    font-size: 1rem;
    font-weight: 400;
    color: var(--ink-soft);
    margin-bottom: 1.25rem;
    max-width: none;
  }

  h1 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(2.6rem, 7vw, 7.5rem);
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--ink);
    max-width: none;
  }

  .dimmed {
    color: #c8c8c8;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    background: var(--ink);
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.85rem 1.75rem;
    border-radius: 100px;
    margin-top: 2.75rem;
    transition: opacity 0.15s;
    letter-spacing: 0;
  }
  .cta-btn:hover { opacity: 0.75; }

  /* ── Intro: photo + caption ── */
  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1.5rem 4.5rem;
    gap: 1.25rem;
  }

  .intro-photo {
    width: 120px;
    height: 120px;
    object-fit: cover;
    object-position: center 15%;
    border-radius: 50%;
    filter: grayscale(6%) contrast(1.03);
  }

  .intro-lines {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: 0.8rem;
    color: var(--ink-muted);
    line-height: 1.75;
  }

  .intro-lines a { color: var(--ink-muted); text-decoration-color: transparent; }
  .intro-lines a:hover { color: var(--ink); }

  /* ── Labels ── */
  .label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  /* ── Credentials ── */
  .cred-stack { display: flex; flex-direction: column; }

  .cred-block { padding: 1.5rem 0; }

  .cred-block--second { border-top: 1px solid var(--line); }

  .cred-title {
    font-weight: 500;
    font-size: 0.88rem;
    margin-bottom: 0.5rem;
    max-width: none;
  }

  .cred-block p:not(.cred-title) {
    font-size: 0.88rem;
    color: var(--ink-muted);
    max-width: none;
  }

  /* ── Publications ── */
  .publications ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .publications li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-left: 1rem;
    border-left: 1px solid var(--line);
  }

  .publications a {
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration-color: transparent;
  }
  .publications a:hover { text-decoration-color: var(--ink-muted); }

  .pub-meta {
    font-size: 0.78rem;
    color: var(--ink-muted);
    max-width: none;
  }

  /* ── Social ── */
  .social-links {
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin-top: 1.5rem;
  }

  .social-links a { color: var(--ink-muted); }
  .social-links a:hover { color: var(--ink); text-decoration-color: var(--ink-muted); }

  .dot { margin: 0 0.35rem; color: var(--line); }

  /* ── Email ── */
  .email {
    display: inline-block;
    font-size: 1.3rem;
    font-weight: 300;
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    margin-top: 1.25rem;
    transition: opacity 0.15s;
  }
  .email:hover { opacity: 0.45; }

  /* ── Footer ── */
  footer { border-top: 1px solid var(--line); }

  .footer-inner {
    padding-top: 1.75rem;
    padding-bottom: 1.75rem;
    font-size: 0.78rem;
    color: var(--ink-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .hero { padding: 3rem 1.5rem 3.5rem; }
    .intro { padding: 3rem 1.5rem 3.5rem; }
  }
</style>
